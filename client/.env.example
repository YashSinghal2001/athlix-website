# Athlix client environment variables
#
# IMPORTANT: every VITE_-prefixed variable is embedded into the public client
# bundle and is therefore visible to anyone. NEVER put API keys, access tokens,
# service keys, database credentials, or any secret in a VITE_ variable.
# All secrets live in the backend (see ../server/.env).

# OPTIONAL. Base URL of the Athlix backend API.
# Leave empty to use a same-origin "/api/apply" (recommended in production
# behind a reverse proxy; the Vite dev proxy handles this in development).
# Set only if the API is hosted on a different origin, e.g. https://api.athlix.co
VITE_API_URL=
