{
  "name": "athlix-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Secure backend API for Athlix coaching application submissions.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "node --check src/index.js && node --check src/app.js && for f in src/lib/*.js src/middleware/*.js src/routes/*.js; do node --check \"$f\" || exit 1; done",
    "lint": "eslint .",
    "test:smoke": "node test/smoke.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@sentry/node": "10.67.0",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "4.22.2",
    "express-rate-limit": "8.6.0",
    "google-auth-library": "10.9.0",
    "helmet": "8.3.0",
    "libphonenumber-js": "^1.13.9",
    "nodemailer": "9.0.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "globals": "^16.5.0"
  }
}
