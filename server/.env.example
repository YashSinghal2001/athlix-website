# ─────────────────────────────────────────────────────────────────────────
# Athlix backend configuration — SERVER-SIDE ONLY.
# These values are NEVER shipped to the browser. Do not prefix with VITE_.
# Copy to `.env` and fill in real values for production.
# ─────────────────────────────────────────────────────────────────────────

# Port the API listens on.
PORT=8787

# Comma-separated list of allowed browser origins (CORS).
# e.g. https://athlix.co,https://www.athlix.co
CLIENT_ORIGIN=http://localhost:5173

# Set to 1 (or a hop count) ONLY when running behind a trusted reverse proxy
# (Nginx, Vercel, Cloudflare, a load balancer). This makes rate limiting use
# the real client IP from X-Forwarded-For. Leave 0 when exposed directly.
TRUST_PROXY=0

# Rate limiting (optional overrides). Defaults: 5 submissions per IP per hour.
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=3600000

# ── Lead destination (CRM / email provider / webhook) — pick what you use ──
# The form submission is forwarded here from the SERVER, so the secret never
# reaches the client. If left empty, submissions are accepted and logged only
# (useful for local dev).
LEAD_WEBHOOK_URL=
# Optional bearer token / API key sent as `Authorization: Bearer <token>`.
LEAD_WEBHOOK_TOKEN=

# Optional: separate CRM endpoint + key (used if you forward to a CRM too).
CRM_API_URL=
CRM_API_KEY=
